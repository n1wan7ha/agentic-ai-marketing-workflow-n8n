      ],
      "id": "a1841a0d-3bac-4d89-8247-c48b6bee3d6e",
      "name": "HTTP Request1"
    },
    {
      "parameters": {
        "jsCode": "// Get the search results from the previous node\nconst searchResults = $input.first().json;\n\n// Get the original company data from the Loop node\n// Note: We use $('Loop Over Items') to get the data that started this loop iteration\nconst companyData = $('Loop Over Items').item.json;\n\nlet foundWebsite = \"\";\nlet foundEmail = \"\";\n\n// Helper function to check if a URL is a social media site\nfunction isSocialMedia(url) {\n  const socialDomains = ['linkedin.com', 'facebook.com', 'instagram.com', 'twitter.com', 'youtube.com', 'tiktok.com', 'glassdoor.com'];\n  return socialDomains.some(domain => url.toLowerCase().includes(domain));\n}\n\n// 1. Try to find a valid website in the organic search results\nif (searchResults.organic && searchResults.organic.length > 0) {\n  for (const result of searchResults.organic) {\n    const link = result.link || \"\";\n    // If the link is NOT social media, we assume it's the company site\n    if (link && !isSocialMedia(link)) {\n      foundWebsite = link;\n      break; // Stop after finding the first valid website\n    }\n  }\n}\n\n// 2. Try to find an email in the snippets (simple extraction)\nconst allSnippets = searchResults.organic ? searchResults.organic.map(r => r.snippet).join(\" \") : \"\";\nconst emailMatch = allSnippets.match(/([a-zA-Z0-9._-]+@[a-zA-Z0-9._-]+\\.[a-zA-Z0-9._-]+)/gi);\nif (emailMatch && emailMatch.length > 0) {\n  // Filter out junk emails (like example.com or wix.com if needed)\n  foundEmail = emailMatch[0];\n}\n\n// 3. Update the company data with the new findings\n// We prioritize the new website, but fallback to the one from LinkedIn if nothing found\ncompanyData.website = foundWebsite || companyData.website || \"\";\ncompanyData.email = foundEmail || companyData.email || \"\";\ncompanyData.googleSearchSuccess = !!foundWebsite;\n\nreturn companyData;"
      },
