    {
      "parameters": {
        "jsCode": "// 1. Get the Search Results\nconst searchResults = $input.first().json;\n\n// 2. CRITICAL FIX: Get the original Inputs (Industry, City) from the first node\n// We use $('Edit Fields') to bypass the HTTP node and get your starting data\nconst globalInputs = $('Edit Fields').first().json;\n\n// Debug Log\nconsole.log(\"Processing results for:\", globalInputs.targetCity);\n\n// Handle empty results\nif (!searchResults.organic || searchResults.organic.length === 0) {\n  return [{\n    error: \"No companies found\",\n    timestamp: new Date().toISOString()\n  }];\n}\n\nconst companies = searchResults.organic.map((item, index) => {\n  // --- LinkedIn Logic (Same as before) ---\n  const linkedinUrl = item.link || \"\";\n  let companyName = \"\";\n  let linkedinHandle = \"\";\n  \n  if (linkedinUrl.includes('linkedin.com/company/')) {\n    const urlParts = linkedinUrl.split('/');\n    const handleIndex = urlParts.findIndex(part => part === 'company') + 1;\n    if (handleIndex < urlParts.length) {\n      linkedinHandle = urlParts[handleIndex];\n      companyName = linkedinHandle\n        .replace(/-/g, ' ').replace(/_/g, ' ')\n        .split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ');\n    }\n  }\n  \n  if (!companyName || companyName === \"Unknown Company\") {\n    companyName = (item.title || \"\").replace(/\\| LinkedIn| on LinkedIn| - LinkedIn/i, '').trim();\n  }\n  \n  // --- Snippet Parsing (Same as before) ---\n  let website = \"\";\n  const snippet = item.snippet || \"\";\n  const urlRegex = /(https?:\\/\\/[^\\s]+\\.(com|lk|io|org|net|co))[^\\s]*/gi;\n  const urls = snippet.match(urlRegex);\n  if (urls && urls.length > 0) {\n    const validUrl = urls.find(u => !u.includes('linkedin') && !u.includes('facebook') && !u.includes('twitter'));\n    if (validUrl) website = validUrl.replace(/[.,)]+$/, '');\n  }\n  \n  let employeeSize = \"\";\n  const employeeMatch = snippet.match(/(\\d+)\\s*(followers|employees|staff)/i);\n  if (employeeMatch) employeeSize = `${employeeMatch[1]} ${employeeMatch[2].toLowerCase()}`;\n\n  // --- RETURN OBJECT (Now with CORRECT Inputs) ---\n  return {\n    companyName: companyName || `Company ${index + 1}`,\n    linkedinUrl: linkedinUrl,\n    website: website,\n    \n    // NOW THESE WILL WORK:\n    industry: globalInputs.targetIndustry, \n    city: globalInputs.targetCity,\n    country: globalInputs.targetCountry,\n    \n    snippet: snippet,\n    employeeSize: employeeSize,\n    searchPosition: item.position || index + 1,\n    timestamp: new Date().toISOString()\n  };\n});\n\n// Deduplication\nconst uniqueCompanies = [];\nconst seenUrls = new Set();\ncompanies.forEach(company => {\n  if (company.linkedinUrl && !seenUrls.has(company.linkedinUrl)) {\n    seenUrls.add(company.linkedinUrl);\n    uniqueCompanies.push(company);\n  }\n});\n\nreturn uniqueCompanies.length > 0 ? uniqueCompanies : [companies[0]];"
      },
