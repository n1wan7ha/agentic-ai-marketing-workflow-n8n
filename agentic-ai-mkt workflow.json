    {
      "parameters": {
        "jsCode": "// 1. Get the Raw Text from Groq (Fixed for Groq format)\nconst response = $input.first().json;\nconst fullText = response.choices ? response.choices[0].message.content : \"\";\n\n// 2. Get Previous Data (to keep passing it through)\nconst companyData = $('Code in JavaScript2').item.json;\n\nlet socialPost = \"\";\nlet hashtags = [];\n\nif (fullText) {\n  // Split by newlines to separate tags from text\n  const lines = fullText.split('\\n');\n  const postLines = [];\n  \n  lines.forEach(line => {\n    if (line.trim().startsWith('#')) {\n      // Extract hashtags\n      const tags = line.match(/#\\w+/g);\n      if (tags) hashtags.push(...tags);\n    } else if (line.trim()) {\n      // Keep normal text\n      postLines.push(line.trim());\n    }\n  });\n  \n  socialPost = postLines.join('\\n\\n');\n}\n\n// 3. Fallback if AI failed\nif (!socialPost) {\n  socialPost = `Excited to connect with ${companyData.companyName}! We are exploring how AI automation can transform the ${companyData.industry} sector.`;\n}\nif (hashtags.length === 0) {\n  hashtags = ['#AI', '#Automation', '#B2B', '#Growth'];\n}\n\n// 4. Output Combined Data\nreturn {\n  ...companyData, \n  socialMediaPost: socialPost,\n  socialHashtags: hashtags.join(' '),\n  postGeneratedAt: new Date().toISOString(),\n  emailStatus: \"SENT\" \n};"
      },
