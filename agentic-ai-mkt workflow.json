    {
      "parameters": {
        "url": "https://api.hunter.io/v2/domain-search",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "domain",
              "value": "={{\n  (() => {\n    // 1. Try to use the website we found\n    if ($json.website && $json.website.includes('://')) {\n      try {\n        // Create a URL object to strip http/https and paths\n        const url = new URL($json.website);\n        return url.hostname.replace('www.', '');\n      } catch (e) {\n        // If URL parsing fails, ignore and move to fallback\n      }\n    }\n\n    // 2. Fallback: Guess the domain from the Company Name\n    // Example: \"Colombo Software\" -> \"colombosoftware.com\"\n    const cleanName = $json.companyName ? $json.companyName.toLowerCase().replace(/[^a-z0-9]/g, '') : \"unknown\";\n    return `${cleanName}.com`;\n  })()\n}}"
            },
            {
              "name": "api_key",
              "value": "={{ $env.HUNTER_API_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        1040,
