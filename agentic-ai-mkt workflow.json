      ],
      "id": "ccc90255-27d4-454b-af1c-21a26c52c4bb",
      "name": "HTTP Request2",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// 1. Get the AI Email Draft (from Groq/HTTP Request)\n// Note: Since this node is after Groq, $input.first() contains the AI's email draft.\nconst aiResponse = $input.first().json;\n\n// 2. Get the specific company details from the previous step\n// We look back at 'Code in JavaScript1' because Groq/HTTP Request usually drops the other fields.\nconst companyData = $('Code in JavaScript1').item.json;\n\n// 3. Get the ORIGINAL search inputs from Node 1 (Edit Fields)\n// This ensures we have a fallback for City/Country if the company data is missing it.\nconst searchInputs = $('Edit Fields').first().json;\n\n// --- SMART EXTRACTION LOGIC ---\n\n// A. Phone Number Scanner (New!)\n// Looks for patterns like +94 77... or 011-2... or (011) 2...\nlet phone = companyData.phone || \"\";\nif (!phone && companyData.snippet) {\n   const phoneMatch = companyData.snippet.match(/(?:\\+?\\d{1,3}[-. ]?)?\\(?\\d{2,3}\\)?[-. ]?\\d{3}[-. ]?\\d{4}/);\n   if (phoneMatch) phone = phoneMatch[0];\n}\n\n// B. Improved \"Founded Year\" Scanner\n// Catches: \"Est. 2010\", \"Since 1999\", \"Established 2015\"\nlet founded = companyData.foundedYear || \"\";\nif (!founded && companyData.snippet) {\n   const yearMatch = companyData.snippet.match(/(?:founded|est\\.?|established|since)\\s*[:\\-]?\\s*(\\d{4})/i);\n   if (yearMatch) founded = yearMatch[1];\n}\n\n// C. Improved \"Company Type\" Scanner\n// Catches: Pvt Ltd, Inc, LLC, etc.\nlet type = companyData.companyType || \"\";\nif (!type && companyData.snippet) {\n   const typeMatch = companyData.snippet.match(/\\b(Pvt\\s*Ltd|Ltd|Inc|LLC|Corp|Private\\s*Limited)\\b/i);\n   if (typeMatch) type = typeMatch[0];\n}\n\n// D. Resolve Email\n// We use the email that was already found in previous steps\nlet finalEmail = companyData.email || \"\";\n\n// E. Resolve Website (Smart Inference)\n// If website is missing but we have an email (e.g. name@company.com), use the domain\nlet finalWebsite = companyData.website || \"\";\nif (!finalWebsite && finalEmail.includes('@')) {\n  const domain = finalEmail.split('@')[1];\n  // Filter out generic email providers so we don't accidentally list gmail.com as the website\n  if (domain && !['gmail.com', 'yahoo.com', 'outlook.com', 'hotmail.com'].includes(domain)) {\n    finalWebsite = `www.${domain}`;\n  }\n}\n\n// F. Resolve Location & Industry (Fallback Logic)\n// We use specific company data first. If missing, we use the Global Search Inputs from Node 1.\nconst finalCity = companyData.city || searchInputs.targetCity || searchInputs.city || \"\";\nconst finalCountry = companyData.country || searchInputs.targetCountry || searchInputs.country || \"\";\nconst finalIndustry = companyData.industry || searchInputs.targetIndustry || searchInputs.industry || \"\";\n\n// G. Resolve Employee Size\n// If missing, check the snippet text one last time\nlet finalEmployees = companyData.employeeSize || \"\";\nif (!finalEmployees && companyData.snippet) {\n   const sizeMatch = companyData.snippet.match(/(\\d+[-+]\\d*|\\d+)\\s*(employees|staff|people)/i);\n   if (sizeMatch) finalEmployees = sizeMatch[0];\n}\n\n// --- OUTPUT FINAL CLEAN ROW ---\nreturn {\n  timestamp: new Date().toISOString(),\n  \n  // Core Info\n  companyName: companyData.companyName,\n  industry: finalIndustry,\n  city: finalCity,\n  country: finalCountry,\n  \n  // Contact Info\n  website: finalWebsite,\n  email: finalEmail,\n  phone: phone,                  // <--- New Smart Field\n  linkedinUrl: companyData.linkedinUrl || \"\",\n  \n  // Details\n  employeeSize: finalEmployees,\n  foundedYear: founded,          // <--- Improved Smart Field\n  companyType: type,             // <--- Improved Smart Field\n  snippet: companyData.snippet || \"\",\n  \n  // AI Content (The Email Draft)\n  // Checks if the AI response structure matches Groq's standard output\n  draftEmail: aiResponse.choices ? aiResponse.choices[0].message.content : (aiResponse.content || \"AI generation failed\"),\n  \n  // Status Metadata\n  status: finalEmail ? \"Lead Found\" : \"Company Found (No Email)\",\n  emailFound: finalEmail ? \"YES\" : \"NO\",\n  websiteVerified: finalWebsite ? \"YES\" : \"NO\",\n  hunterCredits: 1,\n  serperCredits: 1\n};"
      },
